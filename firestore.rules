rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: chargebacks
    // Document ID: {chargebackId}
    // Fields:
    //   - id: string (required)
    //   - paymentDate: string (required)
    //   - email: string (required)
    //   - reasonCode: string (required)
    //   - amount: number (required)
    //   - merchant: string (required)
    //   - status: string (required, enum: ['Won', 'Lost', 'Pending'])
    //   - lossReason: string (optional)
    //   - uid: string (required)
    //   - history: list (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isGerchikTeam() {
      return isAuthenticated() && request.auth.token.email.matches(".*@gerchik\\.team");
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidChargeback(data) {
      return hasOnlyAllowedFields(['id', 'paymentDate', 'email', 'reasonCode', 'amount', 'merchant', 'status', 'lossReason', 'uid', 'history']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.paymentDate is string && data.paymentDate.size() > 0 && data.paymentDate.size() < 50 &&
             data.email is string && data.email.size() <= 100 &&
             data.reasonCode is string && data.reasonCode.size() > 0 && data.reasonCode.size() < 50 &&
             data.amount is number && data.amount >= 0 &&
             data.merchant is string && data.merchant.size() <= 100 &&
             data.status in ['Won', 'Lost', 'Pending'] &&
             (!('lossReason' in data) || (data.lossReason is string && data.lossReason.size() <= 500)) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             (!('history' in data) || data.history is list);
    }

    match /chargebacks/{chargebackId} {
      allow read: if isGerchikTeam();
      allow create: if isGerchikTeam() && 
                    hasRequiredFields(['id', 'paymentDate', 'email', 'reasonCode', 'amount', 'merchant', 'status', 'uid']) &&
                    isValidChargeback(request.resource.data) && 
                    uidUnchanged();
      allow update: if isGerchikTeam() && 
                    isValidChargeback(request.resource.data) && 
                    uidNotModified();
      allow delete: if isGerchikTeam();
    }
  }
}
