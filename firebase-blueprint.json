{
  "entities": {
    "Chargeback": {
      "title": "Chargeback",
      "description": "A record of a chargeback dispute",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "email": { "type": "string", "format": "email" },
        "reasonCode": { "type": "string" },
        "amount": { "type": "number" },
        "merchant": { "type": "string" },
        "status": { "type": "string", "enum": ["Won", "Lost", "Pending"] },
        "lossReason": { "type": "string" },
        "uid": { "type": "string", "description": "User ID of the owner" }
      },
      "required": ["id", "paymentDate", "email", "reasonCode", "amount", "merchant", "status", "uid"]
    }
  },
  "firestore": {
    "/chargebacks/{chargebackId}": {
      "schema": { "$ref": "#/entities/Chargeback" },
      "description": "Stores chargeback records"
    }
  }
}
